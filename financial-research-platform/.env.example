# Application Settings
APP_NAME=FinancialResearchPlatform
DEBUG=False
VERSION=1.0.0

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/financial_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# API Keys (Replace with your own)
GROQ_API_KEY=your_groq_api_key_here
NEWS_API_KEY=your_news_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# File storage
REPORTS_DIR=./reports
CHARTS_DIR=./charts

# Security / CORS
API_KEY=your_secure_api_key
AUTH_ENABLED=False
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Rate Limiting
RATE_LIMIT_ANALYSIS=10/minute
RATE_LIMIT_STATUS=60/minute
RATE_LIMIT_REPORTS=120/minute

# Circuit Breaker
CIRCUIT_BREAKER_FAIL_MAX=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60

# Cache TTLs (Seconds)
CACHE_TTL_ANALYSIS=3600
CACHE_TTL_PROGRESS=86400
CACHE_TTL_NEWS=1800
CACHE_TTL_TECHNICAL=900
